[global]
    monitor = 0
    follow = keyboard
    width = 350
    offset = 10x10
    progress_bar = true
    indicate_hidden = yes
    shrink = no
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    frame_width = 2
    frame_color = "#fdf6e3"
    separator_color = frame
    sort = yes
    font = MonoLisa i3b4cx Bold Italic 9
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    ellipsize = middle
    icon_position = left
    max_icon_size = 48
    corner_radius = 0
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    background = "#1C1917"
    foreground = "#B4BDC3"
    frame_color = "#403833"
    timeout = 5

[urgency_normal]
    background = "#1C1917"
    foreground = "#B4BDC3"
    frame_color = "#fdf6e3"
    timeout = 10

[urgency_critical]
    background = "#1C1917"
    foreground = "#B4BDC3"
    frame_color = "#DE6E7C"
    timeout = 0
